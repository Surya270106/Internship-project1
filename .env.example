# ===========================================
# Employee Sentiment Analysis - Environment Variables
# ===========================================
# This project does not require API keys since TextBlob runs locally.
# Copy this file to .env and update as needed.

# Optional: Data file path (default: test.csv)
DATA_FILE=test.csv

# Optional: Output directory for visualizations (default: visualizations)
OUTPUT_DIR=visualizations

# Optional: Random seed for reproducibility (default: 42)
RANDOM_STATE=42

# Optional: Sentiment thresholds
POSITIVE_THRESHOLD=0.1
NEGATIVE_THRESHOLD=-0.1

# Optional: Flight risk threshold (negative messages in 30-day window)
FLIGHT_RISK_THRESHOLD=4

# Optional: Test split ratio (default: 0.2)
TEST_SIZE=0.2
